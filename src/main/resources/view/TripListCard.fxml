<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1">

  <padding>
    <Insets top="8" right="15" bottom="8" left="15"/>
  </padding>

  <VBox spacing="6" HBox.hgrow="ALWAYS">

    <HBox spacing="10" alignment="CENTER_LEFT">
      <Label fx:id="id" styleClass="cell_big_label" prefWidth="30"/>
      <Label fx:id="name" styleClass="cell_big_label"/>
    </HBox>

    <FlowPane fx:id="tags" hgap="6" vgap="4"/>

    <HBox spacing="10">

      <HBox fx:id="startDateBox" spacing="5" alignment="CENTER_LEFT">
        <ImageView fitHeight="14" fitWidth="14">
          <image>
            <Image url="@/images/calendar.png"/>
          </image>
        </ImageView>
        <Label fx:id="startDate" styleClass="cell_small_label"/>
      </HBox>

      <HBox fx:id="endDateBox" spacing="5" alignment="CENTER_LEFT">
        <ImageView fitHeight="14" fitWidth="14">
          <image>
            <Image url="@/images/calendar.png"/>
          </image>
        </ImageView>
        <Label fx:id="endDate" styleClass="cell_small_label"/>
      </HBox>

    </HBox>

    <HBox spacing="15">

      <HBox fx:id="phoneBox" spacing="5" alignment="CENTER_LEFT">
        <ImageView fitHeight="14" fitWidth="14">
          <image>
            <Image url="@/images/phone.png"/>
          </image>
        </ImageView>
        <Label fx:id="phone" styleClass="cell_small_label"/>
      </HBox>

      <HBox fx:id="addressBox" spacing="5" alignment="CENTER_LEFT">
        <ImageView fitHeight="14" fitWidth="14">
          <image>
            <Image url="@/images/address.png"/>
          </image>
        </ImageView>
        <Label fx:id="address" styleClass="cell_small_label"/>
      </HBox>

      <HBox fx:id="emailBox" spacing="5" alignment="CENTER_LEFT">
        <ImageView fitHeight="14" fitWidth="14">
          <image>
            <Image url="@/images/email.png"/>
          </image>
        </ImageView>
        <Label fx:id="email" styleClass="cell_small_label"/>
      </HBox>

    </HBox>

  </VBox>
</HBox>