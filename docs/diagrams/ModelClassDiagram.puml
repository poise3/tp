@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyTripLog" as ReadOnlyTripLog
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class TripLog
Class ModelManager
Class UserPrefs

Class UniqueTripList
Class Trip
Class Name
Class Phone
Class Email
Class Address
Class Tag
Class TripDate

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

TripLog .up.|> ReadOnlyTripLog

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyTripLog
ModelManager -left-> "1" TripLog
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

TripLog *--> "1" UniqueTripList
UniqueTripList --> "~* all" Trip
Trip *--> Name
Trip *--> Phone
Trip *--> Email
Trip *--> Address
Trip *--> "*" Tag
Trip *--> "2" TripDate

Trip : + getNameLowerCase() : String

Trip -[hidden]up--> I
UniqueTripList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email

ModelManager --> "~* filtered" Trip
ModelManager --> "~* sorted" Trip
@enduml
