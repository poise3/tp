@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":TripLogParser" as TripLogParser LOGIC_COLOR
participant ":TagCommandParser" as TagCommandParser LOGIC_COLOR
participant "d:TagCommand" as TagCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("tag 1 scenery")
activate LogicManager

LogicManager -> TripLogParser : parseCommand("tag 1 scenery")
activate TripLogParser

create TagCommandParser
TripLogParser -> TagCommandParser
activate TagCommandParser

TagCommandParser --> TripLogParser
deactivate TagCommandParser

TripLogParser -> TagCommandParser : parse("1 scenery")
activate TagCommandParser

create TagCommand
TagCommandParser -> TagCommand
activate TagCommand

TagCommand --> TagCommandParser :
deactivate TagCommand

TagCommandParser --> TripLogParser : d
deactivate TagCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
TagCommandParser -[hidden]-> TripLogParser
destroy TagCommandParser

TripLogParser --> LogicManager : d
deactivate TripLogParser

LogicManager -> TagCommand : execute(m)
activate TagCommand

TagCommand -> Model : tagPerson(1)
activate Model

Model --> TagCommand
deactivate Model

create CommandResult
TagCommand -> CommandResult
activate CommandResult

CommandResult --> TagCommand
deactivate CommandResult

TagCommand --> LogicManager : r
deactivate TagCommand

[<--LogicManager
deactivate LogicManager
@enduml
